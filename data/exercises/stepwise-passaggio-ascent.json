{
  "id": "stepwise-passaggio-ascent",
  "name": "Stepwise Passaggio Ascent",
  "pedagogy": "Climbs the first five scale degrees on the close vowel 'oo', walking the voice up through the bridge one step at a time. Keeping the vowel narrow lowers the first formant so the turn-over happens gradually and evenly, not as a flip. (Bozeman.)",
  "capability": "range-passaggio",
  "scaleDegrees": [0, 2, 4, 5, 7],
  "syllables": ["oo", "oo", "oo", "oo", "oo"],
  "noteValue": "8n",
  "tempo": 96,
  "voicePartRanges": {
    "soprano": { "lowest": "F4", "highest": "D5", "step": 1 },
    "alto": { "lowest": "C4", "highest": "A4", "step": 1 },
    "tenor": { "lowest": "G3", "highest": "F4", "step": 1 },
    "baritone": { "lowest": "E3", "highest": "B3", "step": 1 }
  },
  "accompaniment": {
    "pattern": "blockChordOnDownbeat",
    "doubleMelody": false,
    "cueType": "bell",
    "cueDurationBeats": 1,
    "voicing": "close"
  },
  "direction": "both",
  "tags": ["passaggio", "range", "bozeman", "close-vowel"]
}
